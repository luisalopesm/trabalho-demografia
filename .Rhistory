# Cada coorte é uma linha diagonal: começa em (ano, 0) e termina em (ano+5, 5)
coortes <- nv |>
mutate(
x_inicio = ano,
y_inicio = 0,
x_fim    = ano + 5,
y_fim    = 5
)
# --- Gráfico 2: Diagrama de Lexis (base com nascimentos) ---
g_lexis <- ggplot() +
# Linhas diagonais de 45° (uma por coorte de nascimento)
geom_segment(
data = coortes,
aes(x = x_inicio, y = y_inicio,
xend = x_fim,  yend = y_fim,
color = nascidos_vivos),
linewidth = 0.7
) +
# Linhas verticais (anos calendário)
geom_vline(xintercept = 2000:2029, color = "grey85", linewidth = 0.3) +
# Linhas horizontais (idades exatas)
geom_hline(yintercept = 0:5, color = "grey85", linewidth = 0.3) +
# Eixos com escala correta para o ângulo de 45°
scale_x_continuous(
name = "Ano calendário",
breaks = seq(2000, 2029, 1),
expand = c(0, 0)
) +
scale_y_continuous(
name = "Idade exata (anos)",
breaks = 0:5,
expand = c(0, 0)
) +
scale_color_viridis_c(
name = "Nascidos\nvivos",
option = "C",
labels = scales::comma_format(big.mark = ".")
) +
coord_fixed(ratio = 1) +     # MUITO IMPORTANTE: força 1:1 para o ângulo de 45°
labs(
title = "Diagrama de Lexis — Coortes de nascimento de Curitiba (2000–2024)",
subtitle = "Cada linha diagonal representa uma coorte; cor proporcional ao tamanho da coorte",
caption = "Fonte: SINASC/DATASUS"
) +
theme_minimal(base_size = 10) +
theme(
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank(),
axis.text.x = element_text(angle = 45, hjust = 1)
)
print(g_lexis)
