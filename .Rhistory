) +
scale_y_continuous(
name = "Idade exata (anos)",
breaks = 0:5,
expand = c(0, 0)
) +
scale_color_viridis_c(
name = "Nascidos\nvivos",
option = "C",
labels = scales::comma_format(big.mark = ".")
) +
coord_fixed(ratio = 1) +     # MUITO IMPORTANTE: força 1:1 para o ângulo de 45°
labs(
title = "Diagrama de Lexis — Coortes de nascimento de Curitiba (2000–2024)",
subtitle = "Cada linha diagonal representa uma coorte; cor proporcional ao tamanho da coorte",
