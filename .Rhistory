# ============================================================
# Questão 1 - Diagrama de Lexis e Probabilidades de Sobrevivência
# Curitiba, 2000-2024 / Coortes 2000-2019
# ============================================================
# --- Pacotes ---
library(tidyverse)
library(janitor)
library(here)
library(scales)
# --- Nascidos vivos (já trabalhado anteriormente) ---
nv_raw <- read_delim(
here("dados", "nascidos-vivos-curitiba.csv"),
delim = ";",
skip = 4,
locale = locale(encoding = "Latin1"),
show_col_types = FALSE
)
nv <- nv_raw |>
clean_names() |>
rename(ano = ano_do_nascimento,
nascidos_vivos = nascim_p_resid_mae) |>
filter(!is.na(ano), ano != "Total") |>
mutate(ano = as.integer(ano)) |>
filter(ano >= 2000, ano <= 2024) |>
arrange(ano)
# --- Óbitos < 5 anos (vindo do Posit Cloud) ---
ob_raw <- read_csv(
here("dados", "obitos_menor5_curitiba_2000_2024.csv"),
show_col_types = FALSE
)
# Agregar por ano de óbito + idade + coorte (somando todas as raças)
# Para a 1a/1b/1c não usamos raça (isso fica para 1d)
ob <- ob_raw |>
group_by(ano_obito, idade_anos, ano_nasc) |>
summarise(n_obitos = sum(n_obitos), .groups = "drop")
# Confere
nrow(nv); head(nv)
nrow(ob); head(ob)
# ============================================================
# Bloco 2 — Estrutura Lexis: paralelogramos por idade × ano × coorte
# ============================================================
# Cada óbito ocupa um paralelogramo definido por:
#   - lado esquerdo: ano calendário (idade x atingida)
#   - lado direito: ano calendário + 1
#   - lado inferior: idade x
#   - lado superior: idade x + 1
#   - coorte: ano de nascimento (define a diagonal de 45° que atravessa)
#
# Para fins de plotagem, vamos representar cada paralelogramo como
# um retângulo diagonal (4 vértices) e colorir pelo número de óbitos.
# Preparar dataframe de paralelogramos para ggplot
lexis_cells <- ob |>
mutate(
# Vértices do paralelogramo (no plano ano calendário × idade)
# Convenção: óbito ocorrido no ano A, idade I, coorte C = A - I (ou A - I - 1)
# Para um óbito da coorte C que morreu em A com idade I:
#   vértice 1 (esq-baixo):  (A,     I)
#   vértice 2 (esq-cima):   (A,     I+1)
#   vértice 3 (dir-cima):   (A+1,   I+1)
#   vértice 4 (dir-baixo):  (A+1,   I)
# Mas o paralelogramo "puro" da coorte é diagonal:
#   x_inicio = A; y_inicio = I; x_fim = A+1; y_fim = I+1
# Centro da célula (para anotação opcional)
x_centro = ano_obito + 0.5,
y_centro = idade_anos + 0.5
)
# Confere
head(lexis_cells)
# ============================================================
# Bloco 3 — Diagrama de Lexis: óbitos por idade × ano × coorte
# ============================================================
# Estratégia visual:
# - Quadrículos (geom_tile) coloridos pelo número de óbitos da coorte
# - Linhas diagonais separando coortes
# - Linhas verticais (anos) e horizontais (idades) de fundo
# - Coorte = ano_obito - idade_anos (triangulo inferior do quadrado)
# - Como cada quadrado tem dois triângulos (duas coortes), vamos
#   plotar como POLÍGONOS triangulares preservando a coorte real
# Cada combinação ano_obito × idade tem até 2 coortes (idade x veio
# da coorte do ano_obito-idade-1 OU do ano_obito-idade).
# Definimos os triângulos:
#   - Triângulo SUPERIOR ESQUERDO:  coorte = ano_obito - idade - 1
#       vértices: (A, I), (A, I+1), (A+1, I+1)
#   - Triângulo INFERIOR DIREITO: coorte = ano_obito - idade
#       vértices: (A, I), (A+1, I), (A+1, I+1)
triangulos <- ob |>
mutate(
triangulo = if_else(ano_nasc == ano_obito - idade_anos,
"inferior", "superior")
) |>
rowwise() |>
mutate(
polygon_id = paste(ano_obito, idade_anos, ano_nasc, sep = "_")
) |>
ungroup()
# Construir os 3 vértices de cada triângulo em formato longo
vertices <- triangulos |>
mutate(
v1_x = ano_obito,
v1_y = idade_anos,
v2_x = if_else(triangulo == "inferior", ano_obito + 1, ano_obito),
v2_y = if_else(triangulo == "inferior", idade_anos, idade_anos + 1),
v3_x = ano_obito + 1,
v3_y = idade_anos + 1
) |>
select(polygon_id, n_obitos, ano_nasc,
v1_x, v1_y, v2_x, v2_y, v3_x, v3_y) |>
pivot_longer(
cols = c(v1_x, v1_y, v2_x, v2_y, v3_x, v3_y),
names_to = c("vertice", ".value"),
names_pattern = "(v[123])_(.)"
)
# --- Gráfico Lexis completo ---
g_lexis_completo <- ggplot() +
# Triângulos coloridos por número de óbitos
geom_polygon(
data = vertices,
aes(x = x, y = y, group = polygon_id, fill = n_obitos),
color = "white", linewidth = 0.2
) +
# Linhas de coortes (diagonais)
geom_segment(
data = nv,
aes(x = ano, y = 0, xend = pmin(ano + 5, 2025), yend = pmin(5, 2025 - ano)),
color = "grey30", linewidth = 0.4, linetype = "dashed", alpha = 0.6
) +
# Eixos
scale_x_continuous(
name = "Ano calendário",
breaks = seq(2000, 2025, 1),
expand = c(0, 0)
) +
scale_y_continuous(
name = "Idade exata (anos)",
breaks = 0:5,
expand = c(0, 0)
) +
scale_fill_viridis_c(
name = "Óbitos",
option = "B",
trans = "log10",
labels = scales::comma_format(big.mark = ".")
) +
coord_fixed(ratio = 1) +
labs(
title = "Diagrama de Lexis — Óbitos de menores de 5 anos",
subtitle = "Curitiba (PR), 2000-2024 | Cor = óbitos por idade × ano × coorte (escala log)",
caption = "Fonte: SIM/DATASUS (microdados). Linhas tracejadas: limites de coortes."
) +
theme_minimal(base_size = 10) +
theme(
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(color = "grey90", linewidth = 0.2),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "right"
)
print(g_lexis_completo)
# --- Gráfico Lexis completo ---
# --- Gráfico Lexis completo (versão final) ---
g_lexis_completo <- ggplot() +
# Triângulos coloridos por número de óbitos (sem borda)
geom_polygon(
data = vertices,
aes(x = x, y = y, group = polygon_id, fill = n_obitos),
color = NA
) +
# Linhas de coortes (diagonais 45°) — em primeiro plano e visíveis
geom_segment(
data = tibble(ano_inicio = 1995:2024),
aes(x = ano_inicio, y = 0,
xend = pmin(ano_inicio + 5, 2025),
yend = pmin(5, 2025 - ano_inicio)),
color = "white", linewidth = 0.5, alpha = 0.7
) +
# Linhas verticais (anos calendário)
geom_vline(xintercept = 2000:2025, color = "white",
linewidth = 0.3, alpha = 0.6) +
# Linhas horizontais (idades)
geom_hline(yintercept = 0:5, color = "white",
linewidth = 0.3, alpha = 0.6) +
# Eixos
scale_x_continuous(
name = "Ano calendário",
breaks = seq(2000, 2025, 1),
expand = c(0, 0)
) +
scale_y_continuous(
name = "Idade exata (anos)",
breaks = 0:5,
expand = c(0, 0)
) +
scale_fill_viridis_c(
name = "Óbitos",
option = "B",
trans = "log10",
labels = scales::comma_format(big.mark = ".")
) +
coord_fixed(ratio = 1) +
labs(
title = "Diagrama de Lexis — Óbitos de menores de 5 anos",
subtitle = "Curitiba (PR), 2000-2024 | Cor = óbitos por idade × ano × coorte (escala log)",
caption = "Fonte: SIM/DATASUS (microdados)."
) +
theme_minimal(base_size = 10) +
theme(
plot.title = element_text(face = "bold"),
panel.grid.minor = element_blank(),
panel.grid.major = element_blank(),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "right"
)
print(g_lexis_completo)
# ============================================================
# Questão 1b - Probabilidade de sobreviver até 5 anos exatos
# Coortes 2000-2019
# ============================================================
# Total de óbitos por coorte (somando todas as idades 0-4 e todos os anos)
obitos_por_coorte <- ob |>
group_by(coorte = ano_nasc) |>
summarise(obitos_total_5 = sum(n_obitos), .groups = "drop")
# Juntar com nascidos vivos
sobrevivencia_5 <- nv |>
rename(coorte = ano, nascidos_vivos = nascidos_vivos) |>
left_join(obitos_por_coorte, by = "coorte") |>
mutate(
obitos_total_5 = replace_na(obitos_total_5, 0),
prob_sobrev_5 = 1 - (obitos_total_5 / nascidos_vivos),
prob_morte_5  = 1 - prob_sobrev_5
) |>
filter(coorte >= 2000, coorte <= 2019)
print(sobrevivencia_5, n = 20)
write_csv(sobrevivencia_5, here("output", "q1b_sobrevivencia_5anos.csv"))
g_q1b <- ggplot(sobrevivencia_5, aes(x = coorte, y = prob_sobrev_5)) +
geom_line(color = "#2c7fb8", linewidth = 0.5) +
geom_point(color = "#2c7fb8", size = 2.5) +
geom_text(aes(label = sprintf("%.2f%%", prob_sobrev_5 * 100)),
vjust = -1.2, size = 2.7) +
scale_x_continuous(breaks = 2000:2019) +
scale_y_continuous(
labels = scales::percent_format(accuracy = 0.1),
limits = c(0.98, 1.0),
expand = c(0.02, 0.02)
) +
labs(
title = "Probabilidade de sobreviver à idade exata 5",
subtitle = "Curitiba — coortes de nascimento 2000-2019",
x = "Coorte (ano de nascimento)",
y = "Probabilidade de sobrevivência",
caption = "Fonte: SINASC e SIM/DATASUS. Cálculo por coorte verdadeira."
) +
theme_minimal(base_size = 11) +
theme(
plot.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
panel.grid.minor = element_blank()
)
print(g_q1b)
ggsave(here("output", "q1b_sobrevivencia_5anos.png"),
plot = g_q1b, width = 11, height = 5, dpi = 300, bg = "white")
# Questão 1c - Probabilidade de sobreviver ao 1º aniversário
# Coortes 2000-2023
# ============================================================
# Óbitos com idade 0 por coorte
obitos_idade0_coorte <- ob |>
filter(idade_anos == 0) |>
group_by(coorte = ano_nasc) |>
summarise(obitos_idade0 = sum(n_obitos), .groups = "drop")
# Juntar com nascidos vivos
sobrevivencia_1 <- nv |>
rename(coorte = ano) |>
left_join(obitos_idade0_coorte, by = "coorte") |>
mutate(
obitos_idade0 = replace_na(obitos_idade0, 0),
prob_sobrev_1 = 1 - (obitos_idade0 / nascidos_vivos),
prob_morte_1  = 1 - prob_sobrev_1   # equivalente à TMI por coorte
) |>
filter(coorte >= 2000, coorte <= 2023)
print(sobrevivencia_1, n = 25)
dir.create("output", showWarnings = FALSE)
write_csv(sobrevivencia_1, here("output", "q1c_sobrevivencia_1ano.csv"))
g_q1c <- ggplot(sobrevivencia_1, aes(x = coorte, y = prob_sobrev_1)) +
geom_line(color = "#41ab5d", linewidth = 0.5) +
geom_point(color = "#238b45", size = 2.5) +
geom_text(aes(label = sprintf("%.2f%%", prob_sobrev_1 * 100)),
vjust = -1.2, size = 2.7) +
scale_x_continuous(breaks = 2000:2023) +
scale_y_continuous(
labels = scales::percent_format(accuracy = 0.1),
limits = c(0.98, 1.0),
expand = c(0.02, 0.02)
) +
labs(
title = "Probabilidade de sobreviver ao primeiro aniversário",
subtitle = "Curitiba — coortes de nascimento 2000-2023",
x = "Coorte (ano de nascimento)",
y = "Probabilidade de sobrevivência ao 1º ano",
caption = "Fonte: SINASC e SIM/DATASUS. Cálculo por coorte."
) +
theme_minimal(base_size = 11) +
theme(
plot.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
panel.grid.minor = element_blank()
)
print(g_q1c)
ggsave(here("output", "q1c_sobrevivencia_1ano.png"),
plot = g_q1c, width = 12, height = 5, dpi = 300, bg = "white")
getwd()
list.files()
