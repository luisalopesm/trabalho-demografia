g_lexis <- ggplot() +
# Linhas diagonais de 45° (uma por coorte de nascimento)
geom_segment(
data = coortes,
aes(x = x_inicio, y = y_inicio,
xend = x_fim,  yend = y_fim,
color = nascidos_vivos),
linewidth = 0.7
) +
# Linhas verticais (anos calendário)
geom_vline(xintercept = 2000:2029, color = "grey85", linewidth = 0.3) +
# Linhas horizontais (idades exatas)
geom_hline(yintercept = 0:5, color = "grey85", linewidth = 0.3) +
# Eixos com escala correta para o ângulo de 45°
scale_x_continuous(
name = "Ano calendário",
breaks = seq(2000, 2029, 1),
