# ============================================================
# Questão 1 - Diagrama de Lexis - Curitiba
# Parte 1a: Nascidos vivos 2000-2024 (SINASC)
# ============================================================
# --- Pacotes ---
library(tidyverse)
library(janitor)
library(here)
# --- Leitura do CSV de nascidos vivos ---
# O TABNET exporta com:
# - 4 linhas de cabeçalho informativo (título, fonte, município, período)
# - Separador ";"
# - Encoding Latin1 (por isso aparecem "?" nos textos)
# - Linha "Total" no final que precisa ser removida
nv_raw <- read_delim(
here("dados", "nascidos-vivos-curitiba.csv"),
delim = ";",
skip = 4,                # pula as 4 linhas de cabeçalho do TABNET
locale = locale(encoding = "Latin1"),
show_col_types = FALSE
)
# Inspecionar
print(nv_raw)
# --- Limpeza ---
nv <- nv_raw |>
clean_names() |>                                    # nomes amigáveis
rename(ano = ano_do_nascimento,
nascidos_vivos = nascim_p_resid_mae) |>
filter(!is.na(ano), ano != "Total") |>             # remove linha de total
mutate(ano = as.integer(ano)) |>
filter(ano >= 2000, ano <= 2024) |>
arrange(ano)
print(nv)
summary(nv$nascidos_vivos)
# --- Gráfico 1: série temporal de nascidos vivos ---
g_nv_serie <- ggplot(nv, aes(x = ano, y = nascidos_vivos)) +
geom_col(fill = "#2c7fb8", alpha = 0.85) +
geom_text(aes(label = scales::comma(nascidos_vivos, big.mark = ".")),
vjust = -0.4, size = 2.5) +
scale_x_continuous(breaks = seq(2000, 2024, 2)) +
scale_y_continuous(labels = scales::comma_format(big.mark = ".")) +
labs(
title = "Nascidos vivos por ano de nascimento — Curitiba (2000–2024)",
subtitle = "SINASC, residência da mãe",
x = "Ano do nascimento",
y = "Nascidos vivos",
caption = "Fonte: SINASC/DATASUS"
) +
theme_minimal(base_size = 11) +
theme(plot.title = element_text(face = "bold"))
print(g_nv_serie)
# --- Preparar dados para o Lexis ---
